{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "i18n/**/*",
        "outDir": "dist/src"
      }
    ],
    "watchAssets": true,
    "webpack": true
  },
  "projects": {
    "my-schematics": {
      "type": "library",
      "root": "libs/my-schematics",
      "entryFile": "index",
      "sourceRoot": "libs/my-schematics/src",
      "compilerOptions": {
        "tsConfigPath": "libs/my-schematics/tsconfig.lib.json"
      }
    }
  }
}